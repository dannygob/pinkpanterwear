<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardElevation="2dp"
    app:cardUseCompatPadding="true"
    app:cardCornerRadius="8dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- ORDER ID -->
        <TextView
            android:id="@+id/admin_order_id_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/admin_order_id"
            android:textAppearance="?attr/textAppearanceCaption"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/admin_order_id_text_view"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:textAppearance="?attr/textAppearanceSubtitle1"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/admin_order_id_label"
            app:layout_constraintTop_toTopOf="@id/admin_order_id_label"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="#ORDER123XYZ" />

        <!-- STATUS LABEL (DYNAMIC) -->
        <TextView
            android:id="@+id/admin_order_status_text_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_status_pending"
            android:fontFamily="@font/poppins_medium"
            android:textAppearance="?attr/textAppearanceBody2"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:textColor="@color/white"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/admin_order_id_text_view"
            tools:text="Pending" />

        <!-- USER -->
        <TextView
            android:id="@+id/admin_order_user_name_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/admin_user"
            android:textAppearance="?attr/textAppearanceCaption"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/admin_order_status_text_view" />

        <TextView
            android:id="@+id/admin_order_user_name_text_view"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:textAppearance="?attr/textAppearanceBody1"
            app:layout_constraintStart_toEndOf="@id/admin_order_user_name_label"
            app:layout_constraintTop_toTopOf="@id/admin_order_user_name_label"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="Jane Doe (user@example.com)" />

        <!-- DATE -->
        <TextView
            android:id="@+id/admin_order_date_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/admin_date"
            android:textAppearance="?attr/textAppearanceCaption"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/admin_order_user_name_text_view" />

        <TextView
            android:id="@+id/admin_order_date_text_view"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:textAppearance="?attr/textAppearanceBody2"
            app:layout_constraintStart_toEndOf="@id/admin_order_date_label"
            app:layout_constraintTop_toTopOf="@id/admin_order_date_label"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="2024-03-15 10:30 AM" />

        <!-- TOTAL -->
        <TextView
            android:id="@+id/admin_order_total_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/admin_total"
            android:textAppearance="?attr/textAppearanceCaption"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/admin_order_date_text_view" />

        <TextView
            android:id="@+id/admin_order_total_text_view"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:textAppearance="?attr/textAppearanceBody1"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/admin_order_total_label"
            app:layout_constraintTop_toTopOf="@id/admin_order_total_label"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="$129.97" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>